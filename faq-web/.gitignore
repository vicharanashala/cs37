.env
.env.*
!.env.example
!.env.*.example
!.env.local.example
!.env.template

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── Debug logs ───────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# ─── Certificates / Keys ──────────────────────────────────────────────────────
*.pem
*.key
*.cert
