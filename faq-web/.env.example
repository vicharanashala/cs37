# Environment Configuration
# Copy this file to .env.local and fill in the values

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get from your MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.sd2h.mongodb.net/?appName=Cluster0

# ── RAG FastAPI Backend ───────────────────────────────────────────────────────
# URL of the ViBe_RAG FastAPI server (default: http://localhost:8000)
RAG_API=http://localhost:8000

# ── Institution ───────────────────────────────────────────────────────────────
INSTITUTION_ID=iit-ropar-vicharanashala

# ── Admin Authentication ──────────────────────────────────────────────────────
# Shared admin key for moderation endpoints
# IMPORTANT: Change this in production!
COMMUNITY_ADMIN_KEY=dev-admin

# ── Gemini (RAG Pipeline only) ────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here