# Environment Configuration for ViBe_RAG FastAPI Backend
# Copy this file to .env and fill in the values

# ── Gemini API ────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Same MongoDB instance/cluster as the Next.js app (faq-web .env.local MONGODB_URI).
# Required for /validate-question to write its verdict back to the question doc.
# Get from your MongoDB Atlas dashboard.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=Cluster0

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Path to the ChromaDB persistent storage
CHROMA_PATH=./chroma_db